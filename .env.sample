# Trust Trainer environment sample
# Copy to web/.env.local for the recommended Next.js app.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true
NEXT_PUBLIC_DEMO_SEED=true
ADMIN_REVIEW_TOKEN=
FAMILY_INVITE_SECRET=
DATASET_EXPORT_SECRET=
DEMO_AUTH_ENABLED=true
PERSONALIZATION_MODE=safe_placeholders
PERSONALIZATION_PROFILE_SOURCE=demo_seed

# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
CONVEX_DEPLOY_KEY=

# Privacy / redaction
PII_REDACTION_PROVIDER=openai_privacy_filter
OPENAI_PRIVACY_FILTER_MODEL_PATH=
PRESIDIO_ANALYZER_URL=
PRESIDIO_ANONYMIZER_URL=

# OpenAI - required only for live OpenAI generation.
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-5.4-nano
OPENAI_DRILL_MODEL=gpt-5.4-mini
OPENAI_ESCALATION_MODEL=gpt-5.5
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_IMAGE_MODEL=
OPENAI_REQUEST_TIMEOUT_MS=20000
OPENAI_STORE=false

# Hosted model fallback.
MODEL_FALLBACK_ORDER=openai,openrouter,workers_ai,ollama,deterministic
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CLASSIFIER_MODEL=
OPENROUTER_DRILL_MODEL=
OPENROUTER_REQUIRE_PARAMETERS=true

# Local/offline model fallback.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CLASSIFIER_MODEL=
OLLAMA_DRILL_MODEL=

# Exa - optional but recommended for provenanced real-image/source retrieval.
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_SEARCH_TYPE=auto
EXA_NUM_RESULTS=6
EXA_USE_MODERATION=true
EXA_SOURCE_DOMAINS=

# Cloudflare - optional deployment/security/provider fallback.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_GATEWAY_URL=
CLOUDFLARE_WORKERS_AI_MODEL=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# fal.ai - optional; use only for live synthetic multimodal artifacts.
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/nano-banana/edit
FAL_ALT_IMAGE_MODEL=fal-ai/recraft/v4/text-to-image

# Gemini - optional media/voice sponsor paths.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_VIDEO_MODEL=veo-3.1-generate-preview
GEMINI_LIVE_MODEL=gemini-3.1-flash-live
GEMINI_MUSIC_MODEL=models/lyria-realtime-exp
GEMINI_REQUEST_TIMEOUT_MS=30000

# Adaption Labs - optional batch/admin dataset cleaning, evaluation, and export.
ADAPTION_API_KEY=
ADAPTION_BASE_URL=
ADAPTION_PROJECT_ID=
ADAPTION_DATASET_ID=
ADAPTION_MAX_ROWS=30
ADAPTION_TIMEOUT_MS=20000

# Optional developer/sandbox sponsor tools.
DAYTONA_API_KEY=
DAYTONA_ORG_ID=
CURSOR_API_KEY=

# Optional inbound email simulation/webhook.
# Do not block the demo on real email infrastructure.
EMAIL_WEBHOOK_SECRET=
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=

# Optional public data ingestion.
# Treat live phishing URLs as dangerous and always defang before display.
PHISHTANK_APP_KEY=
KAGGLE_USERNAME=
KAGGLE_KEY=

# Upload/demo asset limits.
MAX_UPLOAD_MB=5
UPLOAD_STORAGE=local
